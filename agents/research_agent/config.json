{
    "name": "Research Agent",
    "description": "Handles research tasks",
    "model": "gpt-4",
    "temperature": 0.7,
    "tools": [
        "search_tool",
        "summarize_tool"
    ],
    "tool_configs": {
        "search_tool": {
            "prompt": "Search for relevant information about: {input}"
        },
        "summarize_tool": {
            "prompt": "Summarize this clearly: {input}"
        }
    }
}
